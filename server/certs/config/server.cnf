# Subject Alternative Names for the broker server certificate.
#
# Why this file exists:
# mbedTLS 2.28 (used on the AMB82 Mini) only matches the connection target
# against SAN entries — not the CN field. If you connect by IP, the cert MUST
# have an IP SAN; if you connect by hostname, it MUST have a DNS SAN.
# Edit the entries below for your environment.
#
# The firmware on the AMB82 uses setServer(IPAddress), which makes
# WiFiSSLClient skip SNI hostname matching while still verifying the full
# chain — so an IP SAN is enough on the device side. DNS SANs matter for
# the recorder container, which connects to the broker by the compose
# service name ("mosquitto"), and for host-side `mosquitto_pub/sub`
# testing on localhost.
#
# Usage: this file is passed to `openssl x509 -extfile` when signing the
# server certificate with the CA. See generate-server.sh.

subjectAltName   = @alt_names
# serverAuth means this cert is allowed to be used by TLS servers.
extendedKeyUsage = serverAuth

[alt_names]
# Pi hostname (mDNS + /etc/hosts).
DNS.1 = stanimir.local
# Loopback for in-container self-tests with mosquitto_pub/sub.
DNS.2 = localhost
# Docker Compose service name — the recorder container connects to
# "mosquitto:8883" over the internal network, so the broker cert must
# include it as a DNS SAN or TLS verification fails.
DNS.3 = mosquitto
# wlan0 AP on the Pi — the AMB82 camera connects to this IP literal.
IP.1  = 10.0.89.1
# Loopback for host-side testing.
IP.2  = 127.0.0.1
