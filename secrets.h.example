#ifndef SECRETS_H
#define SECRETS_H

// ============================================================
// Template. Copy this file to secrets.h (gitignored) and fill
// in real values. secrets.h is referenced by config.h.
// ============================================================

// WiFi
#define WIFI_SSID           "YourWiFiSSID"
#define WIFI_PASSWORD       "YourWiFiPassword"

// MQTT broker. MUST be an IPv4 literal (e.g. "192.168.1.10") when
// MQTT_USE_TLS=1 in config.h -- mbedTLS 2.28 on this platform cannot
// verify hostname SANs. A hostname here is detected and logged as a
// fatal error at boot.
#define MQTT_BROKER         "192.168.1.10"
#define MQTT_USER           "amb82_cam_01"
#define MQTT_PASSWORD       "YourMQTTPassword"

#endif // SECRETS_H
